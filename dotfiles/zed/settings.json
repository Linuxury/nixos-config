// Zed settings — managed via nixos-config/dotfiles/zed/settings.json
// Symlinked by Home Manager: do not edit ~/.config/zed/settings.json directly.
{
  "session": {
    "trust_all_worktrees": true
  },

  // -------------------------------------------------------------------------
  // Appearance
  // -------------------------------------------------------------------------
  "theme": {
    "mode": "dark",
    "dark": "Catppuccin Mocha",
    "light": "Catppuccin Latte"
  },
  "icon_theme": "Material Icon Theme",
  "window_background_appearance": "blurred",
  "ui_font_size": 16,
  "buffer_font_size": 15,

  // -------------------------------------------------------------------------
  // Editor behaviour
  // -------------------------------------------------------------------------
  "vim_mode": true,
  "relative_line_numbers": true,

  // -------------------------------------------------------------------------
  // Terminal — use fish as the shell
  // -------------------------------------------------------------------------
  "terminal": {
    "shell": {
      "program": "/etc/profiles/per-user/linuxury/bin/fish"
    }
  },

  // -------------------------------------------------------------------------
  // Direnv — pick up .envrc automatically
  // -------------------------------------------------------------------------
  "load_direnv": "shell_hook",

  // -------------------------------------------------------------------------
  // AI Assistant — local Ollama (llm-start must be running first)
  //
  // Open the assistant panel with:  Ctrl+?  or  cmd palette → "assistant"
  // The Ollama server must be running — use llm-start in terminal first.
  // To change model: update "model" here and make sure it's been pulled.
  // -------------------------------------------------------------------------
  "assistant": {
    "enabled": true,
    "version": "2",
    "default_model": {
      "provider": "ollama",
      "model": "qwen2.5:14b"
    }
  },
  "language_model": {
    "ollama": {
      "api_url": "http://localhost:11434"
    }
  }
}
