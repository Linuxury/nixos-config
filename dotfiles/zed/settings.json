// Zed settings — managed via nixos-config/dotfiles/zed/settings.json
// Symlinked by Home Manager: do not edit ~/.config/zed/settings.json directly.
{
  "session": {
    "trust_all_worktrees": true
  },

  // -------------------------------------------------------------------------
  // Appearance
  // -------------------------------------------------------------------------
  "theme": {
    "mode": "dark",
    "dark": "Matugen Dark",
    "light": "Catppuccin Latte"
  },
  "icon_theme": "Material Icon Theme",
  "window_background_appearance": "blurred",
  "ui_font_size": 16,
  "buffer_font_size": 15,

  // -------------------------------------------------------------------------
  // Editor behaviour
  // -------------------------------------------------------------------------
  "vim_mode": true,
  "relative_line_numbers": true,

  // -------------------------------------------------------------------------
  // Terminal — use zsh as the shell
  // -------------------------------------------------------------------------
  "terminal": {
    "shell": {
      "program": "/etc/profiles/per-user/linuxury/bin/zsh"
    }
  },

  // -------------------------------------------------------------------------
  // Direnv — pick up .envrc automatically
  // -------------------------------------------------------------------------
  "load_direnv": "shell_hook",

  // -------------------------------------------------------------------------
  // AI Assistant — Agent Panel (ACP) with Claude Code
  //
  // Open the agent panel with:  Ctrl+?  or  cmd palette → "agent panel"
  // First time: run /login in a Claude thread to authenticate with your subscription
  // -------------------------------------------------------------------------
  "assistant": {
    "enabled": true,
    "version": "2"
  }
}
