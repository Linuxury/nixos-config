# Ensure NixOS setuid wrappers always take priority — nix shells can displace them
typeset -U path
path=(/run/wrappers/bin $path)

# Default editor — Helix for both terminal and "visual" contexts.
# Most tools check VISUAL first, then fall back to EDITOR.
export EDITOR=hx
export VISUAL=hx

# Canonical path to the nixos-config repo — used by nru and other tools
export NIXOS_CONFIG=$HOME/nixos-config

# System info on startup
fastfetch

# ---------------------------------------------------------------------------
# Completion styling
# ---------------------------------------------------------------------------
zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Z}'
zstyle ':completion:*' list-colors "${(s.:.)LS_COLORS}"

# ---------------------------------------------------------------------------
# NixOS management functions
#
# Config lives at ~/nixos-config (symlinked from /etc/nixos).
# The hostname is picked up automatically from the flake.
# Abbreviations for one-liner commands are defined declaratively in home.nix
# via programs.zsh.zsh-abbr.abbreviations — they expand inline before running.
# ---------------------------------------------------------------------------

# Rebuild and switch to the current flake config.
nr() {
  sudo -v
  sudo nixos-rebuild switch --flake "$NIXOS_CONFIG" |& nom
}

# Rebuild into boot (applies on next reboot, not immediately).
nrb() {
  sudo -v
  sudo nixos-rebuild boot --flake "$NIXOS_CONFIG" |& nom
}

# Test rebuild — activates without touching the boot entry.
nrt() {
  sudo -v
  sudo nixos-rebuild test --flake "$NIXOS_CONFIG" |& nom
}

# Rebuild + pull latest nixpkgs before switching.
# Pulls latest git changes first so the build always reflects what's in the repo.
nru() {
  echo "→ Pulling latest changes from $NIXOS_CONFIG..."
  git -C "$NIXOS_CONFIG" pull || return 1
  nix flake update nixpkgs --flake "$NIXOS_CONFIG"
  sudo -v
  sudo nixos-rebuild switch --flake "$NIXOS_CONFIG" |& nom
}

# ---------------------------------------------------------------------------
# OpenCode — runs with OpenRouter API
# ---------------------------------------------------------------------------
opencode() {
  ANTHROPIC_API_KEY="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" \
  ANTHROPIC_BASE_URL="https://openrouter.ai/api" \
  command opencode "$@"
}

# ---------------------------------------------------------------------------
# Local environment variables — loaded from ~/.env.local if it exists
# Use this for API keys and secrets not tracked in git
# Example: ANTHROPIC_API_KEY=sk-ant-...
# ---------------------------------------------------------------------------
[[ -f "$HOME/.env.local" ]] && source "$HOME/.env.local"
